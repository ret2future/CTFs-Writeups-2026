diff --git a/src/builtins/builtins-array.cc b/src/builtins/builtins-array.cc
index b9288c7409a..2d2b4c55511 100644
--- a/src/builtins/builtins-array.cc
+++ b/src/builtins/builtins-array.cc
@@ -1895,5 +1895,52 @@ BUILTIN(ArrayFromAsync) {
   return ReadOnlyRoots(isolate).undefined_value();
 }
 
+BUILTIN(ArraySwapIt) {
+  HandleScope scope(isolate);
+  Factory* factory = isolate->factory();
+  USE(factory);
+
+  if (args.length() < 0) return ReadOnlyRoots(isolate).undefined_value();
+
+  Handle<Object> receiver = args.receiver();
+  
+  if (!receiver->IsJSArray()) {
+     return ReadOnlyRoots(isolate).undefined_value();
+  }
+
+  Handle<JSArray> array = Handle<JSArray>::cast(receiver);
+  
+  if (!array->HasFastElements(isolate)) {
+      return *array;
+  }
+
+  ElementsKind kind = array->GetElementsKind();
+  
+  if (array->length().Number() < 1) {
+    return *array;
+  }
+
+  if (kind == PACKED_ELEMENTS || kind == PACKED_DOUBLE_ELEMENTS) {
+      ElementsKind target_kind = (kind == PACKED_ELEMENTS) 
+                                ? PACKED_DOUBLE_ELEMENTS 
+                                : PACKED_ELEMENTS;
+      
+      Handle<Map> new_map = JSObject::GetElementsTransitionMap(array, target_kind);
+      
+      if (!new_map.is_null()) {
+          array->set_map(*new_map, kReleaseStore);
+      }
+  }
+
+  return *array;
+}
+
 }
 }
